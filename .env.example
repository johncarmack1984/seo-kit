# Copy to .env (gitignored) and fill what you use — or export the same variables
# any other way (shell profile, direnv, a secrets manager). Real environment
# variables win over .env values. Every key is optional: a provider missing its
# key skips cleanly and says what to add.

# --- Tier 0 (free) ---
# Search Console: path to the downloaded OAuth *Desktop app* client JSON.
# First run `seo-kit auth gsc` to do the one-time consent; the token is cached in secrets/.
GSC_OAUTH_CLIENT_JSON=./secrets/gsc_client.json
PAGESPEED_API_KEY=
BING_WEBMASTER_API_KEY=
GITHUB_TOKEN=
# Google Trends needs no key.

# --- Tier 1: SERP + keyword volume (implemented; opt in via config.toml) ---
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
# SERPER_API_KEY=

# --- Tier 2: GEO / LLM citation probes (implemented; opt in via config.toml; any subset of engines works) ---
# PERPLEXITY_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# --- Tier 3: backlinks / competitor (stub; keys unused until implemented) ---
# AHREFS_API_KEY=
# SEMRUSH_API_KEY=
