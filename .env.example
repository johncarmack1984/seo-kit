# Copy to .env (gitignored). Mirror real values into 1Password / AWS Secrets Manager.
# Only Tier 0 is needed to start; the rest stay blank until a tier is promoted.

# --- Tier 0 (free, active) ---
# Search Console: path to the downloaded OAuth *Desktop app* client JSON.
# First run `seo-kit auth gsc` to do the one-time consent; the token is cached in secrets/.
GSC_OAUTH_CLIENT_JSON=./secrets/gsc_client.json
PAGESPEED_API_KEY=
BING_WEBMASTER_API_KEY=
GITHUB_TOKEN=
# Google Trends needs no key.

# --- Tier 1: SERP + volume (stub; leave blank until promoted) ---
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
# SERPER_API_KEY=

# --- Tier 2: GEO / LLM citation probes (stub) ---
# PERPLEXITY_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# --- Tier 3: backlinks / competitor (stub) ---
# AHREFS_API_KEY=
# SEMRUSH_API_KEY=
