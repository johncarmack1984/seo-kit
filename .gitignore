# secrets - never commit
.env
secrets/*
!secrets/.gitkeep

# machine-level provider config - built-in defaults apply without it
config.toml

# generated audit output
reports/*
!reports/.gitkeep

# python / uv
.venv/
__pycache__/
*.pyc
.uv/
dist/
*.egg-info/

# playwright browser cache (if installed into project)
.cache/
